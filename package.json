{
  "name": "codachi",
  "version": "0.1.0",
  "description": "A tamagotchi that lives in your Claude Code statusline",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codachi": "dist/index.js",
    "codachi-hook": "dist/hook.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "bench": "npm run build && node scripts/bench.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "tamagotchi",
    "pet",
    "claude-code",
    "statusline",
    "ascii-art",
    "terminal",
    "cli"
  ],
  "author": "vincent-k2026",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-k2026/codachi.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
